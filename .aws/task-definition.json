{
    "family": "laporlur-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "laporlur-container",
            "image": "image-will-be-updated-by-github-actions",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 5000,
                    "hostPort": 5000,
                    "protocol": "tcp"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/laporlur",
                    "awslogs-region": "ap-southeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::[ID_AKUN_AWS_KAMU]:role/ecsTaskExecutionRole"
}